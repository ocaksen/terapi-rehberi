@import "tailwindcss";

@theme {
  /* Ana renk: sıcak teal — güven + doğa + sakinlik */
  --color-brand-50:  #edfaf7;
  --color-brand-100: #d0f2ea;
  --color-brand-200: #9ae0d0;
  --color-brand-300: #5ecab5;
  --color-brand-400: #30b49a;
  --color-brand-500: #1e9b83;
  --color-brand-600: #167a68;
  --color-brand-700: #125e50;
  --color-brand-800: #0d4439;
  --color-brand-900: #082e27;

  /* Krem: sıcak şeftali beyazı */
  --color-cream-50:  #fffaf7;
  --color-cream-100: #fff3ec;
  --color-cream-200: #fde8d8;

  /* Aksan renkler için custom */
  --color-coral:   #f4735a;
  --color-amber:   #f5b84a;
  --color-lavender:#a78bfa;
  --color-sky:     #60c4f0;

  --font-sans: var(--font-inter), system-ui, sans-serif;
}

:root {
  --background: #fffaf7;
  --foreground: #111827;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  font-size: 16px;
  line-height: 1.6;
}

h1, h2, h3, h4 {
  font-family: var(--font-sans);
  letter-spacing: -0.02em;
  color: #0f172a;
}

p {
  color: #374151;
}

@layer base {
  * {
    box-sizing: border-box;
  }
}

/* Kayan gradient arka plan — hero için */
@keyframes gradient-shift {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.hero-gradient {
  background: linear-gradient(
    135deg,
    #faf7f2 0%,
    #f7e8d8 25%,
    #fdf6f0 50%,
    #f5efe6 75%,
    #faf7f2 100%
  );
  background-size: 300% 300%;
  animation: gradient-shift 10s ease infinite;
}

/* Smooth scroll */
html {
  scroll-behavior: smooth;
}

/* TypewriterText — dark hero'da beyaz cursor */
.hero-dark-text span[class*="text-brand-500"] {
  color: var(--color-brand-300);
}

/* Dark section için kart hover efekti */
.glass-card {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

@layer components {
  .btn-primary {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-xl bg-brand-500 text-white font-semibold text-sm hover:bg-brand-600 transition-colors duration-200 cursor-pointer;
  }

  .btn-outline {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-xl border-2 border-brand-500 text-brand-700 font-semibold text-sm hover:bg-brand-50 transition-colors duration-200 cursor-pointer;
  }

  .card {
    @apply bg-white rounded-2xl border border-cream-200 shadow-sm;
  }

  .section-label {
    @apply text-xs font-semibold uppercase tracking-widest text-brand-600;
  }
}

                    <rect x="6" y="26" width="14" height="14" rx="3" fill="#fbbf24"/>
                    <rect x="22" y="26" width="14" height="14" rx="3" fill="#f87171"/>
                    <rect x="14" y="10" width="14" height="14" rx="3" fill="#60a5fa"/>
                    <rect x="6" y="14" width="6" height="6" rx="2" fill="#fbbf24" opacity="0.5"/>
                    <rect x="30" y="14" width="6" height="6" rx="2" fill="#f87171" opacity="0.5"/>
                  </svg>

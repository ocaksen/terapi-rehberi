                    <ellipse cx="24" cy="28" rx="16" ry="13" fill="#fda4af" stroke="#f43f5e" strokeWidth="1.5"/>
                    <path d="M36 22c2-2 4-1 4 2s-2 5-4 4" fill="#fda4af" stroke="#f43f5e" strokeWidth="1.5"/>
                    <rect x="20" y="10" width="8" height="5" rx="2" fill="#f43f5e"/>
